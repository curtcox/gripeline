name: 12.8-variables-typed
mapping: typed
spec: 12.8
expect: contains
=== dot ===
digraph {
  git[label="git describe --tags"]
  ver[gl_role=value, shape=oval]
  echo[label="echo \"building $ver\""] tee[label="tee"] log[shape=note,label="build.log"]
  git -> ver [gl_name="ver"]
  ver -> echo
  echo -> tee -> log
}
=== bash ===
ver=$(git describe --tags)
echo "building $ver"
tee
build.log
